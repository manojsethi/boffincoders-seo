# Mongo
MONGODB_URI=mongodb://localhost:27017/boffin-seo-v2

# Backend
BACKEND_PORT=7010
BACKEND_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:7011

# Web
NEXT_PUBLIC_API_URL=http://localhost:7010

# Agenda (Mongo backend; Redis NOT required)
AGENDA_COLLECTION=agendaJobs
AGENDA_PROCESS_EVERY=30 seconds
AGENDA_DEFAULT_LOCK_LIFETIME_MS=600000

# Crawl4AI
CRAWL4AI_URL=http://localhost:11235
CRAWL4AI_API_TOKEN=

# AI providers — dynamic router.
# Cheap-tier order: AI_DEFAULT_PROVIDER -> openrouter -> groq -> openai -> local.
# Premium-tier order: openrouter -> openai -> anthropic -> groq -> local.
# Anthropic is only used when explicitly requested or premium tier.
AI_DEFAULT_PROVIDER=openrouter
AI_MONTHLY_BUDGET_USD=50

# OpenRouter — first choice. Single key unlocks many models.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_CHEAP=meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL_PREMIUM=anthropic/claude-3.5-sonnet
OPENROUTER_REFERER=http://localhost:7011
OPENROUTER_APP_NAME=Boffin SEO v2

# Groq — second choice. Fast inference, free tier.
GROQ_API_KEY=

# OpenAI — third choice.
OPENAI_API_KEY=

# Anthropic — escalation only.
ANTHROPIC_API_KEY=

# Local OpenAI-compatible server (Ollama, LM Studio, vLLM). Last fallback.
AI_LOCAL_MODEL_URL=
AI_LOCAL_MODEL_NAME=llama3.1

# Google integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Per-provider callback URIs are derived from this base. Final URIs:
#   GSC: <base>/api/integrations/gsc/callback
#   GA4: <base>/api/integrations/ga4/callback
# Must match the redirect URIs configured in Google Cloud Console.
GOOGLE_OAUTH_REDIRECT_BASE=http://localhost:7010
# Separate from OAuth — used only for PageSpeed Insights / CrUX (replaces old GOOGLE_API_KEY).
PAGESPEED_API_KEY=

# Symmetric secret used to encrypt OAuth refresh/access tokens at rest with AES-256-GCM.
# Either a base64-encoded 32-byte key OR any passphrase (scrypt-derived to 32 bytes).
# REQUIRED before storing or decrypting OAuth tokens.
ENCRYPTION_KEY=

LOG_LEVEL=info
NODE_ENV=development
